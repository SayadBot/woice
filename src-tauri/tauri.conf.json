{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Woice",
  "identifier": "woice",
  "version": "0.0.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Woice",
        "width": 1024,
        "height": 768,
        "minWidth": 720,
        "minHeight": 640,
        "decorations": false,
        "visible": false,
        "shadow": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/sounds/*": "sounds/"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:woice.db"]
    }
  }
}
